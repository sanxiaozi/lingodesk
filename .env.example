# ===== 必填(三项)=====
# 官方门户 bot 的 token(BotFather 创建;用户私聊它自助开通。自托管单人用 = 你自己的 bot)
BOT_TOKEN=
# Claude API key(翻译引擎)
ANTHROPIC_API_KEY=
# 租户 token 加密密钥:openssl rand -hex 32 生成。⚠️ 换掉会让已存租户 token 全部失效
TOKEN_SECRET=

# ===== 可选 =====
# 管理员 Telegram user.id(私聊门户 bot 可用 /tenants /grant /disable 等管理命令)
ADMIN_USER_ID=
# OpenAI 兜底(Claude 偶发故障时自动切换,建议填)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== 计费(Telegram Stars 订阅;自托管默认关=所有人无限)=====
# 官方云托管设 1 启用;留空 = 不计费
BILLING_ENABLED=
# Pro 月订阅价格(Telegram Stars)
PRICE_STARS=500
# 免费版每月出站翻译回复额度(条)
FREE_QUOTA=300

# ===== 以下通常不用改 =====
# (控制台群、用户身份全部运行时自动注册:群里发 /bind 即绑定,无需任何 ID 配置)
# 翻译模型
LLM_MODEL=claude-haiku-4-5
# 数据库位置
DATABASE_URL=file:./dev.db
# 新客户首条只发表情/无文本时,延迟多少毫秒自动发开场白
GREET_DELAY_MS=30000
GREETING=Hi 👋 Thanks for reaching out! How can I help you today?
# Topic 多少天无往来后自动归档
ARCHIVE_AFTER_DAYS=7
# 文件本地存档目录
STORAGE_DIR=storage
