# ===== LingoDesk 核心配置 =====
# BotFather 的 Bot Token(绑定到你的 Telegram Business 账号)
BOT_TOKEN=

# 控制台论坛超级群 chat_id(-100 开头;把 bot 拉进群、群设置里开启「话题/Topics」)
FORUM_CHAT_ID=

# 首次 business 连接建立后可回填;运行时会自动刷新并持久化,留空也行
BUSINESS_CONNECTION_ID=

# 你的 Telegram user.id(用于区分:入站=客户消息 / 出站=你在真人号自己发的)
OWNER_USER_ID=

# ===== AI(Claude 主 + OpenAI 兜底;至少填一个,建议都填) =====
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== 可选 =====
DATABASE_URL=file:./dev.db
# 新客户首条只发表情/无文本时,延迟多少毫秒自动发开场白
GREET_DELAY_MS=30000
GREETING=Hi 👋 Thanks for reaching out! How can I help you today?
# Topic 多少天无往来后自动归档
ARCHIVE_AFTER_DAYS=7
# 文件本地存档目录
STORAGE_DIR=storage
