# ===== 必填(就这两项)=====
# BotFather 的 Bot Token
BOT_TOKEN=
# Claude API key(翻译引擎)
ANTHROPIC_API_KEY=

# ===== 可选:OpenAI 兜底(Claude 偶发故障时自动切换,建议填)=====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== 以下全部自动处理,通常不用填 =====
# 控制台论坛群 chat_id:bot 进群自动绑定,或群里发 /bind;想强制指定才填
FORUM_CHAT_ID=
# 你的 Telegram user.id:从 Business 连接事件自动捕获;想强制指定才填
OWNER_USER_ID=
# 首次 business 连接 id:运行时自动捕获并持久化
BUSINESS_CONNECTION_ID=
# 翻译模型
LLM_MODEL=claude-haiku-4-5
# 数据库位置
DATABASE_URL=file:./dev.db
# 新客户首条只发表情/无文本时,延迟多少毫秒自动发开场白
GREET_DELAY_MS=30000
GREETING=Hi 👋 Thanks for reaching out! How can I help you today?
# Topic 多少天无往来后自动归档
ARCHIVE_AFTER_DAYS=7
# 文件本地存档目录
STORAGE_DIR=storage
