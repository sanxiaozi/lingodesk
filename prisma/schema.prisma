// LingoDesk 数据模型 —— M1 多租户:每个租户自己的 bot,一进程 N 个实例。
// 单机先用 SQLite;量大时改 provider = "postgresql" + DATABASE_URL,本文件其余不动。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 一个租户 = 一个提交了自有 bot token 的用户(经官方门户 bot 自助开通)
model Tenant {
  id          String    @id // 提交者(owner)的 Telegram user.id
  botId       String    @unique // 租户 bot 的 user.id(防同一 bot 被重复注册)
  botUsername String    @default("") // 租户 bot 的 @username
  botToken    String // AES-256-GCM 加密存储(密钥 = TOKEN_SECRET)
  name        String    @default("") // 提交者展示名
  username    String    @default("") // 提交者 @username
  nativeLang  String    @default("zh") // 租户母语(入站译入的目标语,ISO 639-1)
  connId      String    @default("") // 最新 business_connection_id(事件/消息实时刷新)
  canReply    Boolean   @default(true) // 连接是否带「回复消息」权限(can_reply,事件刷新)
  ownerUserId String    @default("") // Business 侧 owner user.id(以 business_connection 事件为准)
  forumChatId String? // 控制台论坛群 chat_id(字符串存,防 Int32 溢出;/bind 绑定)
  status      String    @default("active") // active / disabled
  statusNote  String    @default("") // 停用原因(token 失效 / 409 冲突 / 手动)
  // ── 计费(Telegram Stars 订阅) ──
  plan        String    @default("free") // free / pro
  proUntil    DateTime? // Pro 到期时间(续费顺延;到期定时降级 free)
  subChargeId String    @default("") // 最近订阅的 telegram_payment_charge_id(/paysupport、退款用)
  usageMonth  String    @default("") // 当前计量月份 "YYYY-MM"(跨月自动重置)
  usageCount  Int       @default(0) // 当月出站发送条数(免费额度计量)
  contacts    Contact[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 一个联系人 = 某租户的一个客户 + 其常驻控制台 Topic(话题线程)
model Contact {
  id           Int      @id @default(autoincrement())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  tgId         String // 客户 Telegram user.id
  chatId       String // 私聊 chat.id(出站发送用)
  threadId     Int? // 控制台论坛 Topic id
  lang         String   @default("unknown") // 锁定语种(ISO 639-1)
  name         String // 展示名
  archived     Boolean  @default(false) // Topic 是否已归档
  greeted      Boolean  @default(false) // 是否已发过自动开场白
  connId       String? // 该客户最近消息的 business_connection_id(出站匹配 peer 用)
  lastActiveAt DateTime @default(now()) // 末次往来(归档/复活判据)

  messages  Message[]
  assets    Asset[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, tgId])
  @@unique([tenantId, threadId])
}

// 双语消息存档(原文 + 租户母语译文)
model Message {
  id           Int      @id @default(autoincrement())
  contactId    Int
  contact      Contact  @relation(fields: [contactId], references: [id])
  direction    String // in(客户发来) / out(你发出) / manual(你手动回)
  originalText String
  originalLang String   @default("")
  nativeText   String   @default("") // 母语译文(入站)/原话(出站)
  mediaType    String?
  createdAt    DateTime @default(now())
}

// 双向文件/媒体存档
model Asset {
  id        Int      @id @default(autoincrement())
  contactId Int
  contact   Contact  @relation(fields: [contactId], references: [id])
  direction String   @default("in") // in / out
  type      String // photo/voice/document/video
  fileId    String // Telegram 云端引用(可随时重发)
  fileName  String?
  localPath String? // 本地存档路径(可选下载)
  size      Int?
  createdAt DateTime @default(now())
}

// 轻量 KV(运行时杂项,重启恢复)
model AppState {
  key   String @id
  value String
}

// 常用回复模板(每租户;控制台话题里 /t 一键选发,走常规翻译→预览→确认)
model Template {
  id        Int      @id @default(autoincrement())
  tenantId  String
  label     String // 短标签(按钮上显示)
  text      String // 母语话术正文
  createdAt DateTime @default(now())

  @@unique([tenantId, label])
}

// 跨语言群/频道:租户 bot 被拉进的普通群或频道(非控制台群),非目标语消息自动回译文
model GroupChat {
  id         Int      @id @default(autoincrement())
  tenantId   String
  chatId     String // 群/频道 chat_id(字符串存,防 Int32 溢出)
  title      String   @default("")
  kind       String   @default("group") // group / channel
  targetLang String   @default("en") // 译入目标语(ISO 639-1)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@unique([tenantId, chatId])
}

// 按月用量流水(计费口径出站,含群翻译;bumpOutbound 顺带累计,给看板/对账用)
model MonthlyUsage {
  id       Int    @id @default(autoincrement())
  tenantId String
  month    String // "YYYY-MM"
  outCount Int    @default(0)

  @@unique([tenantId, month])
}

// 轻量用户:免 Premium 玩法(内联翻译/私聊转发翻译)的额度与语言偏好。
// 与租户身份独立并存;额度与套餐判断上,有租户的用户以租户为准。
model LiteUser {
  id          String    @id // Telegram user.id
  nativeLang  String    @default("en") // 母语(译入方向)
  targetLang  String    @default("en") // 内联/私聊译出的目标语(/to 设置)
  plan        String    @default("free") // free / pro(无租户的用户也能直接订 Pro)
  proUntil    DateTime?
  subChargeId String    @default("")
  usageMonth  String    @default("")
  usageCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 运营事件:用户遇到的问题埋点(开通失败/权限缺失/发送失败等),日报汇总用。
// 未开通成功的人不会有 Tenant 行,这张表是看见他们的唯一途径。
model OpsEvent {
  id        Int      @id @default(autoincrement())
  userId    String // 遇到问题的 Telegram user.id(可能不是租户)
  username  String   @default("") // @username / 展示名(便于日报直接点名)
  type      String // token_invalid / token_clash / secretary_mode_off / reply_perm_missing / translate_fail / send_fail
  detail    String   @default("") // 具体上下文(bot 名、错误码等)
  createdAt DateTime @default(now())
}
